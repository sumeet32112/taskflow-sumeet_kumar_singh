        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Store auth token from login response', function () {\r",
                  "  pm.response.to.have.status(200);\r",
                  "\r",
                  "  const data = pm.response.json();\r",
                  "\r",
                  "  pm.expect(data).to.have.property('token');\r",
                  "  pm.collectionVariables.set('authToken', data.token);\r",
                  "\r",
                  "  if (data.tokenType) {\r",
                  "    pm.collectionVariables.set('authTokenType', data.tokenType);\r",
                  "  }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"test@example.com\",\r\n  \"password\": \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/auth/login",
              "protocol": "http",
