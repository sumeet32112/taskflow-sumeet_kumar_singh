# ── Database ──────────────────────────────────────────────────────────────
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow

# Port exposed on the host (inside the container it is always 5432)
DB_PORT_EXPOSED=5432

# ── JWT ────────────────────────────────────────────────────────────────────
# REQUIRED: Base64-encoded secret, minimum 256 bits (32 raw bytes → 44 chars).
# Generate a fresh one with:
#   openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── API server ─────────────────────────────────────────────────────────────
SERVER_PORT=8080
